# Files / directories excluded from the WordPress.org plugin ZIP.
# Read by 10up/action-wordpress-plugin-deploy and by `rsync --exclude-from`.
# Anything listed here is dev-only and never ships to end users.
#
# Note: vendor/ and build/ are NOT excluded — they hold bundled production
# dependencies (debi-php, debi-js) generated fresh by .github/workflows/release.yml.

# VCS
.git
.gitignore
.gitattributes
.github

# Dist controls
.distignore

# Local dev env
.wp-env.json
.wp-env.classic.json
.wp-env.multisite.json
.wp-env.override.json
.wp-env
.env
.env.example
.env.local

# Package managers (source manifests, not the resolved deps)
composer.json
composer.lock
package.json
package-lock.json

# Quality tooling
phpcs.xml.dist
phpcs.xml
phpunit.xml.dist
phpunit.xml
.phpunit.result.cache

# Tests + dev scripts + JS sources (built output ships from build/)
tests
bin
/src

# Editor / OS noise
.editorconfig
.vscode
.idea
node_modules

# GitHub-facing docs (README.txt is the WP.org one)
README.md
CHANGELOG.md
CONTRIBUTING.md

# AI agent tooling (dev-only, never ships to end users)
.claude
.cursor
AGENTS.md
CLAUDE.md
