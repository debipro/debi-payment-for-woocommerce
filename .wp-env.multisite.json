{
    "$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/wp-env.json",
    "core": null,
    "phpVersion": "8.1",
    "multisite": true,
    "plugins": [
        "https://downloads.wordpress.org/plugin/woocommerce.latest-stable.zip"
    ],
    "mappings": {
        "wp-content/plugins/debi-payment-for-woocommerce": "."
    },
    "config": {
        "WP_DEBUG": true,
        "WP_DEBUG_LOG": true,
        "WP_DEBUG_DISPLAY": false,
        "WP_ENVIRONMENT_TYPE": "local",
        "SCRIPT_DEBUG": true
    },
    "lifecycleScripts": {
        "afterStart": "npx wp-env run cli wp eval-file wp-content/plugins/debi-payment-for-woocommerce/bin/seed.php"
    }
}
