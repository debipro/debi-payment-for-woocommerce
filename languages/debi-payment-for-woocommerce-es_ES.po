#: class-debipro-payment-gateway.php:39
#: class-debipro-payment-gateway.php:40
msgid "Debi Payment"
msgstr "Pago Debi"

#: class-debipro-payment-gateway.php:107
msgid "The card form could not be loaded. Please refresh and try again."
msgstr "El formulario de tarjeta no se pudo cargar. Por favor recargue la página e intente nuevamente."

#: class-debipro-payment-gateway.php:108
msgid "The card could not be validated. Check the details and try again."
msgstr "La tarjeta no pudo ser validada. Verifique los datos e intente nuevamente."

#: class-debipro-payment-gateway.php:110
msgid "The card form is not ready yet."
msgstr "El formulario de tarjeta todavía no está listo."

#: class-debipro-payment-gateway.php:240
msgid "Enable/Disable"
msgstr "Activar/Desactivar"

#: class-debipro-payment-gateway.php:242
msgid "Enable Custom Payment"
msgstr "Activar método de pago personalizado"

#: class-debipro-payment-gateway.php:246
msgid "Method Title"
msgstr "Título del método"

#: class-debipro-payment-gateway.php:248
msgid "This controls the title"
msgstr "Controla el título"

#: class-debipro-payment-gateway.php:249
msgid "Credit or debit card in installments"
msgstr "Tarjeta de crédito o débito en cuotas"

#: class-debipro-payment-gateway.php:253
msgid "Secret key"
msgstr "Clave secreta"

#: class-debipro-payment-gateway.php:256
msgid "Use sk_test_… for sandbox or sk_live_… for production — the environment is inferred from the prefix. Used server-side only; never exposed to the browser."
msgstr "Use sk_test_… para sandbox o sk_live_… para producción — el entorno se infiere del prefijo. Solo se usa en el servidor; nunca se expone al navegador."

#: class-debipro-payment-gateway.php:259
msgid "Publishable key"
msgstr "Clave publicable"

#: class-debipro-payment-gateway.php:262
msgid "Safe to expose in the browser; the checkout card element uses it (pk_test_… / pk_live_…). Must match the secret key environment."
msgstr "Seguro para exponer en el navegador; el elemento de tarjeta en el checkout lo utiliza (pk_test_… / pk_live_…). Debe coincidir con el entorno de la clave secreta."

#: class-debipro-payment-gateway.php:265
msgid "Webhook URL"
msgstr "URL del Webhook"

#: class-debipro-payment-gateway.php:269
msgid "Webhook signing secret"
msgstr "Secreto de firma del Webhook"

#: class-debipro-payment-gateway.php:272
msgid "Paste the endpoint signing secret from your Debi developers dashboard. Used to verify that incoming webhook events were sent by Debi."
msgstr "Pegue el secreto de firma del endpoint desde el panel de desarrolladores de Debi. Se usa para verificar que los eventos de webhook entrantes fueron enviados por Debi."

#: class-debipro-payment-gateway.php:358
msgid "Test / Setup automatically"
msgstr "Probar / Configurar automáticamente"

#: class-debipro-payment-gateway.php:362
msgid "Uses your secret key to create the endpoint at Debi (subscription.cancelled, subscription.finished) if it does not exist yet, and fills in the signing secret below. Save changes to persist it."
msgstr "Usa su clave secreta para crear el endpoint en Debi (subscription.cancelled, subscription.finished) si no existe aún, y completa el secreto de firma abajo. Guarde los cambios para persistirlo."

#. translators: 1: production dashboard link, 2: testing dashboard link.
#: class-debipro-payment-gateway.php:369
#, php-format
msgid "This site is not publicly reachable, so automatic setup is disabled. Add this URL as a webhook endpoint (events: subscription.cancelled, subscription.finished) in your Debi dashboard — Production: %1$s · Testing: %2$s — then paste its signing secret below."
msgstr "Este sitio no es accesible públicamente, por lo que la configuración automática está deshabilitada. Agregue esta URL como endpoint de webhook (eventos: subscription.cancelled, subscription.finished) en su panel de Debi — Producción: %1$s · Pruebas: %2$s — luego pegue el secreto de firma abajo."

#: class-debipro-payment-gateway.php:425
#: class-debipro-payment-gateway.php:687
msgid "You are not allowed to do this."
msgstr "No tiene permiso para realizar esta acción."

#: class-debipro-payment-gateway.php:429
msgid "Automatic setup is unavailable on local sites."
msgstr "La configuración automática no está disponible en sitios locales."

#: class-debipro-payment-gateway.php:437
msgid "Enter a valid secret key first (sk_test_… or sk_live_…)."
msgstr "Ingrese primero una clave secreta válida (sk_test_… o sk_live_…)."

#: class-debipro-payment-gateway.php:443
msgid "Debi rejected the request. Check the secret key and try again."
msgstr "Debi rechazó la solicitud. Verifique la clave secreta e intente nuevamente."

#: class-debipro-payment-gateway.php:445
msgid "The webhook could not be set up. Please try again."
msgstr "No se pudo configurar el webhook. Por favor intente nuevamente."

#: class-debipro-payment-gateway.php:449
msgid "The endpoint exists but its signing secret was not returned. Copy it from the Debi dashboard."
msgstr "El endpoint ya existe pero no se devolvió su secreto de firma. Cópielo desde el panel de Debi."

#: class-debipro-payment-gateway.php:460
msgid "Webhook created and signing secret saved."
msgstr "Webhook creado y secreto de firma guardado."

#: class-debipro-payment-gateway.php:461
msgid "Existing webhook found; signing secret saved."
msgstr "Webhook existente encontrado; secreto de firma guardado."

#: class-debipro-payment-gateway.php:561
#: class-debipro-payment-gateway.php:857
msgid "Not configured"
msgstr "No configurado"

#: class-debipro-payment-gateway.php:563
msgid "Test"
msgstr "Probar"

#: class-debipro-payment-gateway.php:568
msgid "Saved secret key:"
msgstr "Clave secreta guardada:"

#. translators: 1: production dashboard link, 2: testing dashboard link.
#: class-debipro-payment-gateway.php:579
#, php-format
msgid "Find your keys — Production: %1$s · Testing: %2$s"
msgstr "Encuentre sus claves — Producción: %1$s · Pruebas: %2$s"

#: class-debipro-payment-gateway.php:694
msgid "Enter at least one key before testing."
msgstr "Ingrese al menos una clave antes de probar."

#: class-debipro-payment-gateway.php:714
#: class-debipro-payment-gateway.php:855
msgid "TEST (sandbox)"
msgstr "TEST (sandbox)"

#: class-debipro-payment-gateway.php:715
#: class-debipro-payment-gateway.php:856
msgid "PRODUCTION"
msgstr "PRODUCCIÓN"

#: class-debipro-payment-gateway.php:737
msgid "Not a secret key (must start with sk_test_ or sk_live_)."
msgstr "No es una clave secreta (debe comenzar con sk_test_ o sk_live_)."

#: class-debipro-payment-gateway.php:738
msgid "Not a publishable key (must start with pk_test_ or pk_live_)."
msgstr "No es una clave publicable (debe comenzar con pk_test_ o pk_live_)."

#: class-debipro-payment-gateway.php:744
msgid "The key environment could not be determined from its prefix."
msgstr "No se pudo determinar el entorno de la clave desde su prefijo."

#: class-debipro-payment-gateway.php:754
msgid "Could not reach Debi to verify the key. Please try again."
msgstr "No se pudo conectar con Debi para verificar la clave. Por favor intente nuevamente."

#: class-debipro-payment-gateway.php:763
msgid "Authentication failed: Debi rejected this key."
msgstr "Autenticación fallida: Debi rechazó esta clave."

#. translators: %s is the environment label (TEST/PRODUCTION).
#: class-debipro-payment-gateway.php:775
#, php-format
msgid "OK — %s."
msgstr "OK — %s."

#. translators: %d is the HTTP status code returned by Debi.
#: class-debipro-payment-gateway.php:784
#, php-format
msgid "Debi returned an unexpected response (HTTP %d)."
msgstr "Debi devolvió una respuesta inesperada (HTTP %d)."

#: class-debipro-payment-gateway.php:858
msgid "Keys belong to different environments"
msgstr "Las claves pertenecen a entornos distintos"

#: class-debipro-payment-gateway.php:859
msgid "Secret key must start with sk_test_ or sk_live_"
msgstr "La clave secreta debe comenzar con sk_test_ o sk_live_"

#: class-debipro-payment-gateway.php:860
msgid "Publishable key must start with pk_test_ or pk_live_"
msgstr "La clave publicable debe comenzar con pk_test_ o pk_live_"

#: class-debipro-payment-gateway.php:861
msgid "Testing…"
msgstr "Probando…"

#: class-debipro-payment-gateway.php:862
msgid "Fix the Debi keys before saving."
msgstr "Corrija las claves de Debi antes de guardar."

#: class-debipro-payment-gateway.php:863
msgid "Enter a key before testing."
msgstr "Ingrese una clave antes de probar."

#: class-debipro-payment-gateway.php:864
msgid "Setting up…"
msgstr "Configurando…"

#: class-debipro-payment-gateway.php:865
msgid "Enter your secret key first."
msgstr "Ingrese su clave secreta primero."

#: class-debipro-payment-gateway.php:907
msgid "Order not found."
msgstr "Orden no encontrada."

#: class-debipro-payment-gateway.php:919
msgid "Please enter your card details before paying."
msgstr "Por favor ingrese los datos de su tarjeta antes de pagar."

#: class-debipro-payment-gateway.php:931
msgid "Invalid number of installments selected."
msgstr "Número de cuotas inválido."

#: class-debipro-payment-gateway.php:974
msgid "The payment was declined or could not be processed. Please check your card and try again."
msgstr "El pago fue rechazado o no pudo procesarse. Por favor verifique su tarjeta e intente nuevamente."

#: class-debipro-payment-gateway.php:978
msgid "We could not process the payment. Please try again in a moment."
msgstr "No pudimos procesar el pago. Por favor intente nuevamente en un momento."

#. translators: %1$d is the installment count, %2$s is the installment amount, %3$s is the total amount
#: class-debipro-payment-gateway.php:1025
#, php-format
msgid "%1$d installment of $ %2$s ($ %3$s)"
msgstr "%1$d cuota de $ %2$s ($ %3$s)"

#. translators: %1$d is the installment count, %2$s is the installment amount, %3$s is the total amount
#: class-debipro-payment-gateway.php:1027
#, php-format
msgid "%1$d installments of $ %2$s ($ %3$s)"
msgstr "%1$d cuotas de $ %2$s ($ %3$s)"

#. translators: %1$d is the installment count, %2$s is the installment amount
#: class-debipro-payment-gateway.php:1049
#, php-format
msgid "%1$d installment of $ %2$s (no interest)"
msgstr "%1$d cuota de $ %2$s (sin interés)"

#. translators: %1$d is the installment count, %2$s is the installment amount
#: class-debipro-payment-gateway.php:1051
#, php-format
msgid "%1$d installments of $ %2$s (no interest)"
msgstr "%1$d cuotas de $ %2$s (sin interés)"

#: includes/class-debipro-keys.php:91
msgid "The Secret key must start with sk_test_ or sk_live_. It looks like you pasted a publishable (pk_) key."
msgstr "La clave secreta debe comenzar con sk_test_ o sk_live_. Parece que pegó una clave publicable (pk_)."

#: includes/class-debipro-keys.php:94
msgid "The Secret key environment could not be determined. Use a key starting with sk_test_ (sandbox) or sk_live_ (production)."
msgstr "No se pudo determinar el entorno de la clave secreta. Use una clave que comience con sk_test_ (sandbox) o sk_live_ (producción)."

#: includes/class-debipro-keys.php:100
msgid "The Publishable key must start with pk_test_ or pk_live_. Never paste your secret (sk_) key here."
msgstr "La clave publicable debe comenzar con pk_test_ o pk_live_. Nunca pegue aquí su clave secreta (sk_)."

#: includes/class-debipro-keys.php:103
msgid "The Publishable key environment could not be determined. Use a key starting with pk_test_ (sandbox) or pk_live_ (production)."
msgstr "No se pudo determinar el entorno de la clave publicable. Use una clave que comience con pk_test_ (sandbox) o pk_live_ (producción)."

#: includes/class-debipro-keys.php:108
msgid "The Secret and Publishable keys belong to different environments (test vs live). Use a matching pair."
msgstr "La clave secreta y la clave publicable pertenecen a entornos distintos (test vs live). Use un par que coincida."

