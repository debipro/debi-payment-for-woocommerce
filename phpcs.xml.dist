<?xml version="1.0"?>
<ruleset name="Debi Payment for WooCommerce">
    <description>WordPress + PHPCompatibility rules for the Debi WooCommerce gateway.</description>

    <!-- Scan only the new infrastructure files in this phase. -->
    <!-- The legacy *.php files at the repo root will be rewritten in a follow-up -->
    <!-- and are explicitly excluded below. -->
    <file>bin</file>
    <file>tests</file>

    <!-- WordPress coding standards (core, docs, extra). -->
    <rule ref="WordPress-Extra">
        <!-- Allow short ternary and modern syntax where helpful in tooling code. -->
    </rule>

    <!-- PHPCompatibility: enforce the PHP version range declared in composer.json. -->
    <rule ref="PHPCompatibilityWP"/>
    <config name="testVersion" value="7.4-"/>

    <!-- Text-domain check for translatable strings. -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="debi-payment-for-woocommerce"/>
            </property>
        </properties>
    </rule>

    <!-- Tests follow PSR-4 (PascalCase filenames) and operate on local files; -->
    <!-- the WP file-naming and "use WP_Filesystem" sniffs do not apply here. -->
    <rule ref="WordPress.Files.FileName">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>
    <rule ref="WordPress.WP.AlternativeFunctions">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <!-- Process .php files. -->
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Use parallel processing for speed. -->
    <arg name="parallel" value="8"/>

    <!-- Excluded paths. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>

    <!-- Legacy files (will be rewritten in a follow-up); not linted in this phase. -->
    <exclude-pattern>debi-payment-for-woocommerce.php</exclude-pattern>
    <exclude-pattern>debi.php</exclude-pattern>
    <exclude-pattern>class-wc-debi.php</exclude-pattern>
    <exclude-pattern>uninstall.php</exclude-pattern>
</ruleset>
