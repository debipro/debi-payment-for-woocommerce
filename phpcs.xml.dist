<?xml version="1.0"?>
<ruleset name="Debi Payment for WooCommerce">
    <description>WordPress + PHPCompatibility rules for the Debi WooCommerce gateway.</description>

    <!-- Scan the PSR-4 domain layer (includes/) plus the tooling/tests. -->
    <!-- The legacy view-heavy gateway files at the repo root are rewritten -->
    <!-- incrementally and are excluded below. -->
    <file>bin</file>
    <file>tests</file>
    <file>includes</file>

    <!-- WordPress coding standards (core, docs, extra). -->
    <rule ref="WordPress-Extra">
        <!-- Allow short ternary and modern syntax where helpful in tooling code. -->
    </rule>

    <!-- PHPCompatibility: enforce the PHP version range declared in composer.json. -->
    <rule ref="PHPCompatibilityWP"/>
    <config name="testVersion" value="7.4-"/>

    <!-- Text-domain check for translatable strings. -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="debi-payment-for-woocommerce"/>
            </property>
        </properties>
    </rule>

    <!-- The PSR-4 domain layer (includes/Checkout, /Infrastructure, /Webhook) and -->
    <!-- tests use PascalCase filenames; the WP file-naming sniff does not apply. -->
    <!-- (includes/class-debipro-keys.php keeps the WP convention and is still checked.) -->
    <rule ref="WordPress.Files.FileName">
        <exclude-pattern>tests/*</exclude-pattern>
        <exclude-pattern>includes/Checkout/*</exclude-pattern>
        <exclude-pattern>includes/Infrastructure/*</exclude-pattern>
        <exclude-pattern>includes/Webhook/*</exclude-pattern>
    </rule>
    <rule ref="WordPress.WP.AlternativeFunctions">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <!-- Throwing an exception with a message variable is not screen output. -->
    <rule ref="WordPress.Security.EscapeOutput.ExceptionNotEscaped">
        <exclude-pattern>includes/Infrastructure/*</exclude-pattern>
    </rule>

    <!-- The domain layer calls the Debi SDK, whose service accessors are -->
    <!-- camelCase (e.g. $client->webhookEndpoints); not our variables to rename. -->
    <rule ref="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase">
        <exclude-pattern>includes/Checkout/*</exclude-pattern>
        <exclude-pattern>includes/Infrastructure/*</exclude-pattern>
        <exclude-pattern>includes/Webhook/*</exclude-pattern>
    </rule>

    <!-- Process .php files. -->
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Use parallel processing for speed. -->
    <arg name="parallel" value="8"/>

    <!-- Excluded paths. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <!-- Vendored Debi PHP SDK: third-party source, not linted here. -->
    <exclude-pattern>*/lib/debi-php/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>

    <!-- Legacy files (will be rewritten in a follow-up); not linted in this phase. -->
    <exclude-pattern>debi-payment-for-woocommerce.php</exclude-pattern>
    <exclude-pattern>debi.php</exclude-pattern>
    <exclude-pattern>class-debipro-payment-gateway.php</exclude-pattern>
    <exclude-pattern>uninstall.php</exclude-pattern>
</ruleset>
